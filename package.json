{
  "name": "tnsi-platform",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\" --ignore-unknown",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "eslint": "^9",
    "@tnsi/config": "workspace:*"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx,ts,tsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
